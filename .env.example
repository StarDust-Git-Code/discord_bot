# Required: Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Required for Gemini bot: Google AI API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-2.0-flash-lite)
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional: Comma-separated channel IDs where the Gemini bot auto-replies
# Leave empty to only reply when mentioned or using !ask prefix
GEMINI_ALLOWED_CHANNELS=

# Optional: Command prefix for the bot (default: !ask)
BOT_PREFIX=!ask

# Optional: Comma-separated list of guild IDs the MCP bot is allowed to interact with
# Leave empty to allow all guilds
DISCORD_ALLOWED_GUILDS=

# Optional: Set to false if you disabled these intents in the Developer Portal
DISCORD_MESSAGE_CONTENT=true
DISCORD_GUILD_MEMBERS=true

# Optional: Port for the MCP HTTP server (default: 3000)
MCP_PORT=3000
